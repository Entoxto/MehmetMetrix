{
  "name": "mehmet-metrics",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc -p tsconfig.strict-check.json",
    "test": "vitest run",
    "test:excel": "python Excel/test_parser_logic.py",
    "test:images": "python scripts/test_convert_to_webp.py",
    "validate:data": "python Excel/validate_generated_data.py",
    "validate:images": "node scripts/validate_catalog_images.mjs",
    "preflight:fast": "node scripts/preflight.mjs --fast",
    "preflight": "node scripts/preflight.mjs",
    "build:full": "npm run preflight"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "@types/react": "18.2.66",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.5",
    "typescript": "5.6.3",
    "vitest": "^1.6.1"
  }
}
